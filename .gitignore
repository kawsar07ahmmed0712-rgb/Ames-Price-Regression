# =========================
# Python cache files
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Type checking / tool cache
# =========================
.mypy_cache/
.pytest_cache/
.ruff_cache/
.cache/

# =========================
# Jupyter notebook checkpoints
# =========================
.ipynb_checkpoints/

# =========================
# Virtual environments
# =========================
venv/
env/
.venv/
ENV/

# =========================
# IDE / editor files
# =========================
.vscode/
.idea/

# =========================
# OS generated files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Environment / secret files
# =========================
.env
.env.*
*.env

# =========================
# CatBoost generated files
# =========================
catboost_info/
Notebook/catboost_info/

# =========================
# Prepared / intermediate data
# These are generated from notebooks
# =========================
Notebook/prepared_data/
Notebook/prepared_data_public_safe_v2/

# =========================
# Submission outputs
# Keep only final selected submission if needed
# =========================
Notebook/submission/*
!Notebook/submission/final_stacked_submission.csv

