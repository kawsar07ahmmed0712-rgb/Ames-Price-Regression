# Saved model / artifact files
# =========================
*.pkl
*.pickle
*.joblib
*.sav
*.cbm
*.model

# =========================
# Logs
# =========================
*.log
*.tsv

# =========================
# Temporary files
# =========================
tmp/
temp/
*.tmp
*.bak

# =========================
# Large generated CSV files
# Do not ignore original raw Data folder
# =========================
*_prepared.csv
*_prepared_with_target.csv
full_engineered_combined*.csv
full_data_linear.csv
full_data_tree.csv
X_train_*.csv
X_test_*.csv
y_train*.csv
test_ids.csv

